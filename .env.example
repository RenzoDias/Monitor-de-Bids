# Copie este arquivo para .env e preencha os valores reais.
# NUNCA comite o .env de verdade.

# Chave da API da Anthropic (obrigatória) — usada para classificar bids
ANTHROPIC_API_KEY=sk-ant-api03-...

# Token Personal Access do GitHub (opcional) — usada para publicar dashboard no GitHub Pages
# Necessário escopo: repo
# Sem este token o script ainda roda; só não publica no Pages.
GITHUB_TOKEN=ghp_...

# Nível de log: DEBUG | INFO | WARNING | ERROR (padrão: INFO)
LOG_LEVEL=INFO
